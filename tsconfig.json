{
  "compilerOptions": {
    /* Project */
    "rootDir": "./src",
    "outDir": "./dist",
    /* Environment */
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    /* Types */
    "types": [
      "node"
    ],
    /* Strictness */
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    /* Output */
    "sourceMap": true,
    "declaration": false,
    /* Performance */
    "skipLibCheck": true,
    /* Clean Import */
    "resolveJsonModule": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}